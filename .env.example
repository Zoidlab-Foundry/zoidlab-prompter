# --- ZoidLab Prompter ---
# Shared ZoidLab SSO secret — MUST match the other *.zoidlab.ai apps.
BUILDER_SESSION_SECRET=change-me

# Backend
DATA_DIR=./backend/data
PORT=8400
ENABLE_MOCK_MODELS=true
ENABLE_REAL_MODEL_ROUTING=false
# Comma-separated Nyquest user ids/emails allowed into the approval queue
PROMPTER_ADMINS=

# Frontend
PROMPTER_API_URL=http://127.0.0.1:8400
NYQUEST_API=https://api.nyquest.ai
NYQUEST_APP_ORIGIN=https://app.nyquest.ai
SESSION_COOKIE_DOMAIN=.zoidlab.ai
APP_DOMAIN=prompter.zoidlab.ai

# Local Docker Postgres (the prototype defaults to SQLite; see README)
DATABASE_URL=postgresql://zoidlab:zoidlab@localhost:5432/zoidlab_prompter
